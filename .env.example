# Your Resend API key — from https://resend.com/api-keys
# Free tier (100/day) is enough. You must VERIFY discoverurcredit.online
# in Resend first (add the SPF/DKIM DNS records it gives you, in Cloudflare).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The address every email is sent FROM. Must be on your verified domain.
EMAIL_FROM=Discover Support <support@discoverurcredit.online>

# Port used by the production server (npm start). Dev uses Vite's port.
PORT=4000
